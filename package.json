{
  "name": "nexora",
  "version": "4.0.0",
  "author": {
    "name": "NEXORA",
    "email": "support@nexora.local"
  },
  "description": "Next Generation Business Management System",
  "homepage": "https://nexora.local",
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "postinstall": "prisma generate",
    "desktop": "npm run desktop:run:full",
    "desktop:run:demo": "node scripts/run-electron-desktop.cjs demo",
    "desktop:run:full": "node scripts/run-electron-desktop.cjs full",
    "license:keypair": "node scripts/generate-license-keypair.cjs",
    "license:init": "node scripts/generate-license-keypair.cjs --write-env-file",
    "license:code": "node scripts/generate-activation-code.cjs",
    "desktop:assets": "node scripts/generate-electron-assets.cjs",
    "build:electron": "npm run desktop:assets && npm run build && node scripts/prepare-electron.cjs",
    "build:electron:demo": "node scripts/run-electron-builder.cjs demo installer",
    "build:electron:full": "node scripts/run-electron-builder.cjs full installer",
    "package:electron:demo": "node scripts/run-electron-builder.cjs demo dir",
    "package:electron:full": "node scripts/run-electron-builder.cjs full dir",
    "desktop:build": "npm run build:electron",
    "desktop:pack": "npm run package:electron:full",
    "desktop:pack:demo": "npm run package:electron:demo",
    "desktop:pack:linux": "npm run build:electron && electron-builder --config electron-builder.config.js --linux dir",
    "desktop:dist": "npm run build:electron:full",
    "desktop:dist:demo": "npm run build:electron:demo",
    "desktop:dist:all": "npm run build:electron:demo && npm run build:electron:full",
    "desktop:dist:linux": "npm run build:electron && electron-builder --config electron-builder.config.js --linux AppImage deb",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma db push --force-reset && npm run db:seed",
    "test": "jest",
    "test:watch": "jest --watch",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
